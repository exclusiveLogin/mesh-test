# ===== Meshtastic devices =====
MESHTASTIC_PRODUCER_ADDRESS=192.168.31.140
MESHTASTIC_CONSUMER_ADDRESS=192.168.31.84

MESHTASTIC_PRODUCER_TLS=0
MESHTASTIC_CONSUMER_TLS=0

# ===== Producer routing =====
# Куда отправляет producer:
#   broadcast            - общий чат (видят все в этом канале)
#   self                 - сам себе (только локальная нода)
#   !<hex>               - как на экране устройства, например !0400a878
#   0x<hex> | <decimal>  - тот же id в других форматах
# ВАЖНО: это id ПРИНИМАЮЩЕЙ стороны (consumer). Смотри на экране consumer-устройства
# или в его логах: "Connection '...' firmware identified: ... nodeId=!XXXXXXXX".
MESHTASTIC_PRODUCER_DESTINATION=!0400a878

# Номер канала Meshtastic (0 - Primary, 1..6 - доп, 7 - Admin)
MESHTASTIC_PRODUCER_CHANNEL=0

# Запрашивать ACK (1/0)
MESHTASTIC_PRODUCER_WANT_ACK=1

# Consumer: если указан - пропускаются все пакеты кроме этого канала
# (пусто = показывать все)
MESHTASTIC_CONSUMER_CHANNEL=

# ===== Pipeline =====
BATCH_SIZE=12
THROTTLE_MS=1500
MAX_RETRIES=3
QUEUE_TICK_MS=200
CB_FAILURE_THRESHOLD=3
CB_RESET_MS=10000

# ===== Connection keep-alive =====
# Авто-реконнект при разрыве HTTP-транспорта (1=on, 0=off) и пауза перед попыткой.
AUTO_RECONNECT=1
RECONNECT_DELAY_MS=2000
# Heartbeat-пинг. По умолчанию не нужен: reconnect и так восстанавливает связь,
# а если что-то активно отправляется (producer) - канал и так не молчит.
# Можно включить (например 5000), если видишь частые реконнекты на пассивном consumer.
HEARTBEAT_MS=0

# ===== CLI UI =====
# fullscreen - alt-screen buffer, event-driven редроу (только когда что-то произошло).
#              Никаких таймеров и idle CPU. Логи tslog из @meshtastic/core
#              перехватываются и идут в наш "live log" как "[lib] ...".
# inline     - обычный stdout со скроллингом: каждое событие добавляется строкой вниз.
#              Подходит для pipe/tee/CI.
CLI_UI_MODE=fullscreen

# Путь к файлу с verbose-логами (в fullscreen-режиме используется всегда).
# По умолчанию logs/producer.log и logs/consumer.log.
#PRODUCER_LOG_FILE=logs/producer.log
#CONSUMER_LOG_FILE=logs/consumer.log

# Дублировать наши события в stderr. Имеет смысл только в CLI_UI_MODE=inline,
# в fullscreen режиме игнорируется (иначе stderr порвёт alt-screen).
PRODUCER_VERBOSE_LOGS=0
CONSUMER_VERBOSE_LOGS=0

# Уровень логов внутренней либы @meshtastic/core (tslog).
# 0 silly | 1 trace | 2 debug | 3 info | 4 warn | 5 error | 6 fatal
# Все отфильтрованные строки теперь НЕ пишутся в stdout, а попадают в наш
# dashboard как "[lib] ..." и в файл logs/*.log - дашборд не ломается.
# По умолчанию 4 (warn+). Поставь 1, чтобы видеть TRACE протокола в live log.
MESHTASTIC_LIB_LOG_LEVEL=4
